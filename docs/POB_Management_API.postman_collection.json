    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Organization",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.data.tokens.access_token);",
                  "    pm.collectionVariables.set('refresh_token', json.data.tokens.refresh_token);",
                  "    pm.collectionVariables.set('user_id', json.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organization_name\": \"Offshore Corp\",\n  \"organization_phone\": \"+44 123 456 7890\",\n  \"organization_address\": \"123 Oil Rig Lane, Aberdeen\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"phone_number\": \"+44 987 654 3210\",\n  \"email\": \"john.doe@offshorecorp.com\",\n  \"password\": \"securePwd123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Register a new organization and its system admin user. Returns auth tokens on success.\n\n**Auto-saves:** `access_token`, `refresh_token`, and `user_id` to collection variables."
          },
          "response": [
            {
              "name": "201 – Registered",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"organization registered successfully\",\n  \"data\": {\n    \"user\": {\n      \"id\": \"...\",\n      \"organization_id\": \"...\",\n      \"first_name\": \"John\",\n      \"last_name\": \"Doe\",\n      \"email\": \"john.doe@offshorecorp.com\",\n      \"role\": \"system_admin\",\n      \"is_active\": true\n    },\n    \"tokens\": {\n      \"access_token\": \"...\",\n      \"refresh_token\": \"...\",\n      \"access_token_expires_at\": \"...\",\n      \"refresh_token_expires_at\": \"...\"\n    }\n  }\n}"
            },
            {
              "name": "409 – Conflict",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"email already exists\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.data.tokens.access_token);",
                  "    pm.collectionVariables.set('refresh_token', json.data.tokens.refresh_token);",
                  "    pm.collectionVariables.set('user_id', json.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@offshorecorp.com\",\n  \"password\": \"securePwd123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authenticate with email and password. Returns access and refresh tokens.\n\n**Auto-saves:** `access_token`, `refresh_token`, and `user_id` to collection variables."
          },
          "response": [
            {
              "name": "200 – Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"message\": \"login successful\",\n  \"data\": {\n    \"user\": { \"id\": \"...\", \"email\": \"...\" },\n    \"tokens\": { \"access_token\": \"...\", \"refresh_token\": \"...\" }\n  }\n}"
            },
            {
              "name": "401 – Invalid Credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"status\": \"error\",\n  \"message\": \"invalid credentials\"\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.data.tokens.access_token);",
                  "    pm.collectionVariables.set('refresh_token', json.data.tokens.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            },
            "description": "Use a valid refresh token to obtain a new access/refresh token pair.\n\n**Auto-saves:** `access_token` and `refresh_token` to collection variables."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Invalidates the current user's refresh token. Requires authentication."
          },
          "response": []
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Returns the currently authenticated user's profile."
          },
          "response": []
        },
        {
          "name": "Update Profile (Me)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Doe\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Update the authenticated user's first and last name."
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"securePwd123\",\n  \"new_password\": \"newSecurePwd456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/change-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "change-password"]
            },
            "description": "Change the authenticated user's password. Requires current password verification. Invalidates existing refresh tokens."
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints: register, login, token refresh, logout, and profile management."
    },
